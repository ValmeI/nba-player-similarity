NBA_API_RETRY_WAIT_MIN = 3.0
NBA_API_RETRY_WAIT_MAX = 10.0
NBA_API_TIMEOUT = 30
NBA_API_RATE_LIMIT_DELAY = 0.6

# Frontend variables

API_REQUEST_TIMEOUT = 10

STREAMLIT_TITLE = "NBA Player Similarity Chat"
STREAMLIT_INITIAL_MESSAGE = "Hi! Ask me to find similar NBA players.\n\nYou can try:\n• Just a name: 'LeBron James'\n• Filter by position: 'Find guards similar to Kobe Bryant'\n• Filter by era: 'Players like Shaq from the 90s'\n• Both: 'Show me forwards similar to Larry Bird from the 2000s'"
STREAMLIT_INPUT_PLACEHOLDER = "e.g., 'Guards like Steph Curry' or 'Players similar to Shaq from the 90s'"

