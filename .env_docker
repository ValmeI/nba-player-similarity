FUZZ_THRESHOLD_LOCAL_NAME = 50

LOG_LEVEL=INFO
LOG_TO_CONSOLE=True
LOG_TO_FILE=True
LOG_ERRORS_TO_SEPARATE_FILE=True

# Backend NBA Data loading variables

FETCH_RAW_DATA_FETCH = False
